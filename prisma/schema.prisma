generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Custom fields
  tdee          Int?
  goal          String?   // "loss", "maintain", "gain"
  meals         Meal[]
  dailyStats    DailyStats[]
  fastingLogs   FastingLog[]
  savedMeals    SavedMeal[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Meal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  items       Json?
  calories    Int
  servings    Float    @default(1)
  protein     Float    @default(0)
  carbs       Float    @default(0)
  fat         Float    @default(0)
  sugar       Float    @default(0)
  image       String?
  type        String   // "breakfast", "lunch", "dinner", "snack"
  loggedAt    DateTime @default(now())
}

model SavedMeal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  items       Json?
  calories    Int
  protein     Float    @default(0)
  carbs       Float    @default(0)
  fat         Float    @default(0)
  sugar       Float    @default(0)
}

model DailyStats {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  waterGlasses  Int      @default(0)
  streak        Int      @default(0)

  @@unique([userId, date])
}

model FastingLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime?
}
